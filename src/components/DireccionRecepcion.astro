---
// RecepcionSocial.astro
---

<section class="relative w-full py-8 px-6">
    <!-- ═════════════════════════════════════════════════════════════ -->
    <!-- 🌸 HOJAS DECORATIVAS - Pegadas a los bordes de la pantalla    -->
    <!-- ═════════════════════════════════════════════════════════════ -->

    <!-- ═══ PRIMERA CAPA (ABAJO): Hojas Doradas ═══ -->

    <!-- Hoja dorada izquierda -->
    <img
        src="/imagenes/hojadorada.png"
        alt="hoja dorada"
        class="absolute left-0 top-20 md:top-24 w-18 h-18 lg:w-28 lg:h-28 md:w-20 md:h-20 opacity-0 pointer-events-none z-10"
        id="hoja-dorada-recepcion-left"
    />

    <!-- Hoja dorada derecha (volteada horizontalmente) -->
    <img
        src="/imagenes/hojadorada.png"
        alt="hoja dorada"
        class="absolute right-0 top-20 md:top-24 w-18 h-18 lg:w-28 lg:h-28 md:w-20 md:h-20 opacity-0 pointer-events-none z-10 scale-x-[-1]"
        id="hoja-dorada-recepcion-right"
    />

    <!-- ═══ SEGUNDA CAPA (ENCIMA): Flores Laterales ═══ -->

    <!-- Hoja lateral izquierda -->
    <img
        src="/imagenes/florlateral.png"
        alt="hojas"
        class="absolute left-0 top-24 md:top-24 w-18 h-18 lg:w-28 lg:h-28 md:w-20 md:h-20 opacity-0 pointer-events-none z-[11]"
        id="hoja-recepcion-left"
    />

    <!-- Hoja lateral derecha (volteada horizontalmente) -->
    <img
        src="/imagenes/florlateral.png"
        alt="hojas"
        class="absolute right-0 top-24 md:top-24 w-18 h-18 lg:w-28 lg:h-28 md:w-20 md:h-20 opacity-0 pointer-events-none z-[11] scale-x-[-1]"
        id="hoja-recepcion-right"
    />

    <!-- ═════════════════════════════════════════════════════════════ -->
    <!-- 📦 CONTENEDOR PRINCIPAL                                        -->
    <!-- ═════════════════════════════════════════════════════════════ -->
    <div class="max-w-md mx-auto" id="wrapper-recepcion">
        <!-- RECEPCIÓN SOCIAL -->
        <div class="text-center opacity-0" id="recepcion-content">
            <!-- Título -->
            <h3
                class="text-[#9C7A2E] tracking-[0.2em] uppercase text-xl md:text-2xl lg:text-2xl xl:text-3xl font-semibold mb-6"
            >
                Recepción Social
            </h3>

            <!-- Icono Salón/Arco -->
            <div class="flex justify-center mb-6">
                <img
                    src="/iconos/recepcion.png"
                    alt="Icono Recepción"
                    class="w-16 h-16 md:w-20 md:h-20 object-contain dorado-filter"
                    id="icono-recepcion"
                />
            </div>

            <!-- Nombre del Salón -->
            <p
                class="font-charm text-[#0F3D2E] text-2xl md:text-3xl lg:text-3xl xl:text-4xl mb-3"
            >
                Salón de Eventos "Rossy"
            </p>

            <!-- Dirección -->
            <p class="text-[#0F3D2E]/70 text-base md:text-2xl mb-6">
                Ubicado en la villa 1ro. de mayo
            </p>

            <!-- Hora y Botón -->
            <div class="flex items-center justify-center gap-3 relative">
                <!-- Recuadro de Hora -->
                <div
                    class="bg-transparent border-2 border-gray-400 rounded px-6 py-2.5"
                >
                    <p class="text-sm md:text-2xl text-[#0F3D2E] font-semibold">
                        19:30 HRS.
                    </p>
                </div>

                <!-- Botón Ubicación con MANO -->
                <div class="relative">
                    <a
                        href="https://maps.app.goo.gl/YntP4muTGrgUtMBj9"
                        target="_blank"
                        class="bg-[#0F3D2E] hover:bg-[#0F3D2E]
                    text-white px-6 py-2.5 rounded text-sm md:text-base
                    lg:text-lg xl:text-xl font-semibold transition-all
                    duration-300 shadow-md hover:shadow-lg block"
                        id="boton-recepcion"
                    >
                        Ver ubicación
                    </a>

                    <!-- MANO apuntando al botón -->
                    <img
                        src="/imagenes/mano.png"
                        alt="Presionar aquí"
                        class="absolute -bottom-6 -right-6 md:-bottom-8 md:-right-8 lg:-bottom-10 lg:-right-10 w-10 h-10 md:w-12 md:h-12 lg:w-14 lg:h-14 object-contain opacity-0 pointer-events-none z-20"
                        id="mano-recepcion-pointer"
                    />
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- 🎬 ANIMACIONES CON GSAP                                     -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <script>
        import { gsap } from "gsap";
        import { ScrollTrigger } from "gsap/ScrollTrigger";

        gsap.registerPlugin(ScrollTrigger);

        const initRecepcionSocial = () => {
            console.log("🎉 Iniciando componente Recepción Social...");

            // ═══════════════════════════════════════════════════════
            // ⚙️ ESTADO INICIAL
            // ═══════════════════════════════════════════════════════

            // Contenido principal
            gsap.set("#recepcion-content", {
                opacity: 0,
                y: 30,
            });

            // Flores laterales (ENCIMA)
            gsap.set("#hoja-recepcion-left", {
                opacity: 0,
                x: -20,
                rotation: 0,
                scale: 1,
            });
            gsap.set("#hoja-recepcion-right", {
                opacity: 0,
                x: 20,
                rotation: 0,
                scaleX: -1,
                scaleY: 1,
            });

            // Hojas doradas (ABAJO)
            gsap.set("#hoja-dorada-recepcion-left", {
                opacity: 0,
                x: -20,
                rotation: 0,
                scale: 1,
            });
            gsap.set("#hoja-dorada-recepcion-right", {
                opacity: 0,
                x: 20,
                rotation: 0,
                scaleX: -1,
                scaleY: 1,
            });

            // Mano pointer
            gsap.set("#mano-recepcion-pointer", {
                opacity: 0,
                scale: 0.8,
            });

            // ═══════════════════════════════════════════════════════
            // 🎭 ANIMACIÓN AL ENTRAR
            // ═══════════════════════════════════════════════════════

            ScrollTrigger.create({
                trigger: "#wrapper-recepcion",
                start: "top 80%",
                end: "top 20%",

                onEnter: () => {
                    const tl = gsap.timeline();

                    // 1️⃣ CONTENIDO PRINCIPAL - INMEDIATO (0s)
                    tl.to(
                        "#recepcion-content",
                        {
                            opacity: 1,
                            y: 0,
                            duration: 1.2,
                            ease: "power3.out",
                        },
                        0,
                    )

                        // 2️⃣ FLORES LATERALES (ENCIMA) - A LOS 0.5 SEGUNDOS
                        .to(
                            "#hoja-recepcion-left",
                            {
                                opacity: 0.8,
                                x: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            0.5,
                        )
                        .to(
                            "#hoja-recepcion-right",
                            {
                                opacity: 0.8,
                                x: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            0.5,
                        )

                        // 3️⃣ HOJAS DORADAS (ABAJO) - 1 SEGUNDO DESPUÉS (a los 1.5s)
                        .to(
                            "#hoja-dorada-recepcion-left",
                            {
                                opacity: 0.9,
                                x: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            1.5,
                        )
                        .to(
                            "#hoja-dorada-recepcion-right",
                            {
                                opacity: 0.9,
                                x: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            1.5,
                        )

                        // 4️⃣ MANO - DESPUÉS DE TODO (a los 2.5s)
                        .to(
                            "#mano-recepcion-pointer",
                            {
                                opacity: 1,
                                scale: 1,
                                duration: 0.5,
                                ease: "back.out(2)",
                            },
                            0.5,
                        );

                    // ═══════════════════════════════════════════════════
                    // 🍃 MOVIMIENTOS NATURALES SUAVES (después de entrada)
                    // ═══════════════════════════════════════════════════

                    // Flor recepcion izquierda - Movimiento suave
                    gsap.to("#hoja-recepcion-left", {
                        y: -10,
                        x: -5,
                        rotation: -8,
                        duration: 3.5,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut",
                        delay: 2.5,
                    });

                    // Flor recepcion derecha
                    gsap.to("#hoja-recepcion-right", {
                        y: -8,
                        x: 5,
                        rotation: 8,
                        duration: 3.8,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut",
                        delay: 2.7,
                    });

                    // Hoja dorada izquierda - Balanceo suave
                    gsap.to("#hoja-dorada-recepcion-left", {
                        y: -12,
                        rotation: -10,
                        duration: 4,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut",
                        delay: 2.8,
                    });

                    // Hoja dorada derecha
                    gsap.to("#hoja-dorada-recepcion-right", {
                        y: -11,
                        rotation: 10,
                        duration: 4.3,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut",
                        delay: 3,
                    });

                    // ═══ RESPIRACIÓN SUTIL (SCALE) ═══
                    gsap.to("#hoja-dorada-recepcion-left", {
                        scale: 0.85,
                        duration: 4.5,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut",
                        delay: 3.2,
                    });

                    gsap.to("#hoja-dorada-recepcion-right", {
                        scaleX: -0.85,
                        scaleY: 0.85,
                        duration: 5,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut",
                        delay: 3.5,
                    });

                    // ═══ EFECTO BRISA SUTIL ═══
                    gsap.to("#hoja-recepcion-left", {
                        x: -8,
                        duration: 5.5,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut",
                        delay: 3.8,
                    });

                    gsap.to("#hoja-recepcion-right", {
                        x: 8,
                        duration: 6,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut",
                        delay: 4,
                    });

                    // ═══ ANIMACIÓN DE PRESIONAR BOTÓN (loop infinito) ═══
                    gsap.to("#mano-recepcion-pointer", {
                        scale: 0.9,
                        duration: 0.6,
                        ease: "power1.inOut",
                        repeat: -1,
                        yoyo: true,
                        delay: 3,
                    });
                },

                // ═══════════════════════════════════════════════════════
                // 🔙 ANIMACIÓN AL SALIR (scroll hacia arriba)
                // ═══════════════════════════════════════════════════════

                onLeaveBack: () => {
                    // Detener TODAS las animaciones continuas
                    gsap.killTweensOf("#mano-recepcion-pointer");
                    gsap.killTweensOf("#hoja-recepcion-left");
                    gsap.killTweensOf("#hoja-recepcion-right");
                    gsap.killTweensOf("#hoja-dorada-recepcion-left");
                    gsap.killTweensOf("#hoja-dorada-recepcion-right");

                    const tl = gsap.timeline();

                    // Hacer todo invisible al mismo tiempo
                    tl.to(
                        "#recepcion-content, #hoja-recepcion-left, #hoja-recepcion-right, #hoja-dorada-recepcion-left, #hoja-dorada-recepcion-right, #mano-recepcion-pointer",
                        {
                            opacity: 0,
                            duration: 0.5,
                            ease: "power2.in",
                        },
                    )

                        // Mover el contenido hacia abajo
                        .to(
                            "#recepcion-content",
                            {
                                y: 30,
                                duration: 0.5,
                                ease: "power2.in",
                            },
                            "<",
                        )

                        // Mover flores laterales hacia afuera
                        .to(
                            "#hoja-recepcion-left",
                            {
                                x: -20,
                                y: 0,
                                duration: 0.5,
                                ease: "power2.in",
                            },
                            "<",
                        )
                        .to(
                            "#hoja-recepcion-right",
                            {
                                x: 20,
                                y: 0,
                                duration: 0.5,
                                ease: "power2.in",
                            },
                            "<",
                        )

                        // Mover hojas doradas hacia afuera
                        .to(
                            "#hoja-dorada-recepcion-left",
                            {
                                x: -20,
                                y: 0,
                                duration: 0.5,
                                ease: "power2.in",
                            },
                            "<",
                        )
                        .to(
                            "#hoja-dorada-recepcion-right",
                            {
                                x: 20,
                                y: 0,
                                duration: 0.5,
                                ease: "power2.in",
                            },
                            "<",
                        )

                        // Escalar la mano
                        .to(
                            "#mano-recepcion-pointer",
                            {
                                scale: 0.8,
                                duration: 0.5,
                                ease: "power2.in",
                            },
                            "<",
                        )

                        // Resetear rotaciones y scales
                        .set("#hoja-recepcion-left", {
                            rotation: 0,
                            scale: 1,
                        })
                        .set("#hoja-recepcion-right", {
                            rotation: 0,
                            scaleX: -1,
                            scaleY: 1,
                        })
                        .set("#hoja-dorada-recepcion-left", {
                            rotation: 0,
                            scale: 1,
                        })
                        .set("#hoja-dorada-recepcion-right", {
                            rotation: 0,
                            scaleX: -1,
                            scaleY: 1,
                        });
                },
            });

            console.log(
                "🎉✨ Recepción Social activada - Movimiento natural en hojas!",
            );
        };

        document.addEventListener("DOMContentLoaded", initRecepcionSocial);
        document.addEventListener("astro:page-load", initRecepcionSocial);
    </script>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- 🎨 ESTILOS PARA CONVERTIR IMÁGENES NEGRAS A DORADO          -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <style>
        /* Filtro que convierte imágenes PNG negras al color dorado #9C7A2E */
        .dorado-filter {
            filter: brightness(0) saturate(100%) invert(56%) sepia(77%)
                saturate(419%) hue-rotate(5deg) brightness(94%) contrast(92%);
        }
    </style>
</section>
