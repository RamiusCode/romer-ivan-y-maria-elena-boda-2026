---
// src/layouts/Layout.astro
import "../styles/global.css";
export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="m-0 p-0">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light only" />
    <link rel="icon" type="image/png" href="/iconos/Anillos.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Crimson+Text:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Crimson+Text:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Charm:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- 🖼️ Precargar imagen de fondo de la portada ANTES de renderizar -->
    <link rel="preload" as="image" href="/imagenes/BlancoTextura.webp" />

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        width: 100%;
        height: 100%;
        overflow-x: hidden;
        color-scheme: light only;
        /* 🔒 Color sólido INSTANTÁNEO mientras carga BlancoTextura */
        background-color: #f5f0e8;
      }

      body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        overflow-x: hidden;
        background-image: url("/imagenes/BlancoTextura.png");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        color-scheme: light only;
        background-color: #ffffff;
      }

      main {
        background: transparent !important;
      }

      /* ═══════════════════════════════════════════════════════
         🔒 OVERLAY BLOQUEADOR - Se muestra INSTANTÁNEO antes
         de que cargue cualquier JS. Oculta el contenido de
         fondo mientras la portada no esté lista.
      ═══════════════════════════════════════════════════════ */
      #contenido-principal {
        visibility: hidden;
        opacity: 0;
      }

      /* Cuando la portada ya fue cerrada, se revela el contenido */
      #contenido-principal.contenido-visible {
        visibility: visible;
        opacity: 1;
        transition: opacity 0.5s ease;
      }
    </style>

    <!-- 🔒 Script inline: bloquea scroll INSTANTÁNEAMENTE antes del render -->
    <script is:inline>
      document.documentElement.style.overflow = "hidden";
      document.documentElement.style.height = "100vh";
    </script>
  </head>
  <body class="min-h-screen m-0 p-0">
    <main class="m-0 p-0 overflow-x-hidden">
      <slot />
    </main>
  </body>
</html>
